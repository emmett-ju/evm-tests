      "kind": "upstream_mapped",
      "case_id": "upstream.benchmark.call_context.address.success",
      "family": "state/call-context",
      "description": "Mapped from execution-specs ADDRESS onto an RPC-only deploy/call/storage-assert flow.",
      "namespace_seed": "upstream-call-context-address",
      "upstream_ref": "tests/benchmark/compute/instruction/test_call_context.py::test_call_frame_context_ops[opcode=ADDRESS]",
      "notes": [
        "Upstream intent: benchmark ADDRESS in an external-call frame.",
        "RPC mapping: runtime writes ADDRESS to storage slot0 after deployment, then the harness asserts it against the deployed contract address resolved at runtime.",
        "Admitted because the final contract address is observable from the deployment receipt and can be resolved via placeholders without genesis control."
      ],
      "observe": {
        "storage_address": "$last_contract"
      },
      "filters": {},
      "steps": [
        {
          "action": "deploy_contract",
          "bytecode_init": "0x0f600c6000390f6000f33060005500",
          "bytecode_runtime": "0x3060005500",
          "gas": "0x186a0"
        },
        {
          "action": "wait_receipt",
          "tx_hash": "$last",
          "timeout_seconds": 60
        },
        {
          "action": "invoke_contract",
          "to": "$last_contract",
          "data": "0x",
          "gas": "0xc350",
          "value": "0x0"
        },
        {
          "action": "wait_receipt",
          "tx_hash": "$last",
          "timeout_seconds": 60
        }
      ],
      "expected": {
        "storage": {
          "0x00": "$last_contract_word"
        }
      }
    },
