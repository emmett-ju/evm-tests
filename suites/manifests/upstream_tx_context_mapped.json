  "cases": [
    {
      "kind": "upstream_mapped",
      "case_id": "upstream.benchmark.tx_context.gasprice.success",
      "family": "state/tx-context",
      "description": "Mapped from execution-specs GASPRICE onto an RPC-only deploy/call/storage-assert flow.",
      "namespace_seed": "upstream-tx-context-gasprice",
      "upstream_ref": "tests/benchmark/compute/instruction/test_tx_context.py::test_call_frame_context_ops[opcode=GASPRICE]",
      "notes": [
        "Upstream intent: benchmark GASPRICE in an external-call frame.",
        "RPC mapping: runtime writes GASPRICE to storage slot0 after deployment, then the harness asserts it against the effective gas price observed on the invoke receipt.",
        "Admitted because the invoke transaction receipt exposes the effective gas price truthfully on both mock and jsonrpc backends without block-environment control."
      ],
      "observe": {
        "storage_address": "$last_contract"
      },
      "filters": {},
      "steps": [
        {
          "action": "deploy_contract",
          "bytecode_init": "0x0f600c6000390f6000f33a60005500",
          "bytecode_runtime": "0x3a60005500",
          "gas": "0x186a0"
        },
        {
          "action": "wait_receipt",
          "tx_hash": "$last",
          "timeout_seconds": 60
        },
        {
          "action": "invoke_contract",
          "to": "$last_contract",
          "data": "0x",
          "gas": "0xc350"
        },
        {
          "action": "wait_receipt",
          "tx_hash": "$last",
          "timeout_seconds": 60
        }
      ],
      "expected": {
        "storage": {
          "0x00": "$gas_price_word"
        }
      }
    },
    {
