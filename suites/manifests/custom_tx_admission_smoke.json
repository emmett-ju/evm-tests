{
  "name": "custom-tx-admission-smoke",
  "version": "1",
  "execution_specs_ref": "submodule-pending",
  "suite_version": "0.1.0",
  "chain_profile_version": "1",
  "cases": [
    {
      "kind": "custom_chain",
      "case_id": "custom.tx_admission.calldata_floor_rejection",
      "family": "custom/tx-admission",
      "description": "A large non-zero calldata raw transaction is submitted below the EIP-7623 floor and is expected to be rejected at RPC admission time.",
      "namespace_seed": "custom-tx-admission-calldata-floor",
      "notes": [
        "This proof is RPC-only and stops at submission rejection; it does not fabricate a receipt.",
        "The transaction is signed locally without applying the harness gas-floor rewrite so the declared under-floor gas is preserved."
      ],
      "steps": [
        {
          "action": "eth_sendRawTransaction",
          "transaction": {
            "to": "0xbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
            "gas": "0x5208",
            "data": "",
            "value": "0x0"
          },
          "expect_error": {
            "code": -32000,
            "message_contains": "intrinsic gas"
          }
        }
      ],
      "expected": {
        "rpc_error": {
          "code": -32000,
          "message_contains": "intrinsic gas"
        }
      },
      "observe": {
        "tx_admission_probe": {
          "required_feature": "calldata_floor_eip7623",
          "mode": "intrinsic_gas_floor_rejection"
        }
      },
      "filters": {}
    }
  ]
}
