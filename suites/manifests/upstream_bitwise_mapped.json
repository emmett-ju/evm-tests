      "kind": "upstream_mapped",
      "case_id": "upstream.benchmark.bitwise.test_bitwise.and",
      "family": "state/bitwise",
      "description": "Mapped from execution-specs AND onto an RPC-only deploy/call/storage-assert flow.",
      "namespace_seed": "upstream-bitwise-and",
      "upstream_ref": "tests/benchmark/compute/instruction/test_bitwise.py::test_bitwise[opcode=AND]",
      "notes": [
        "Upstream intent: benchmark AND with specific parameters.",
        "RPC mapping: runtime pushes parameters, executes the opcode, and writes the result to storage slot0.",
        "Admitted because the mathematical result is perfectly deterministic and observable in final storage."
      ],
      "observe": {
        "storage_address": "$last_contract",
        "bitwise_probe": {
          "opcode": "AND",
          "args": [
            115792089237316195423570985008687907853269984665640564039457584007908834671663,
            52435875175126190479447740508185965837690552500527637822603658699938581184513
          ],
          "expected_result": 52435875175126190479447740508185965837690552500527637822603658699934286217217
        }
      },
      "filters": {},
      "steps": [
        {
          "action": "deploy_contract",
          "bytecode_init": "0x6046600c60003960466000f37f73eda753299d7d483339d80809a1d80553bda402fffe5bfeffffffff000000017ffffffffffffffffffffffffffffffffffffffffffffffffffffffffefffffc2f165f5500",
          "bytecode_runtime": "0x7f73eda753299d7d483339d80809a1d80553bda402fffe5bfeffffffff000000017ffffffffffffffffffffffffffffffffffffffffffffffffffffffffefffffc2f165f5500",
          "gas": "0x186a0"
        },
        {
          "action": "wait_receipt",
          "tx_hash": "$last",
          "timeout_seconds": 60
        },
        {
          "action": "invoke_contract",
          "to": "$last_contract",
          "data": "0x",
          "gas": "0xc350"
        },
        {
          "action": "wait_receipt",
          "tx_hash": "$last",
          "timeout_seconds": 60
        }
      ],
      "expected": {
        "storage": {
          "0x00": "0x73eda753299d7d483339d80809a1d80553bda402fffe5bfefffffffe00000001"
        }
      }
    },
