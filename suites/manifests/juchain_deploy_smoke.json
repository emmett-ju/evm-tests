          "bytecode_runtime": "0x00",
          "gas": "0x186a0"
        },
        {
          "action": "wait_receipt",
          "tx_hash": "$last",
          "timeout_seconds": 60
        }
      ],
      "expected": {
        "receipt_status": "0x1",
        "receipt_contract_address": "nonempty",
        "code": "0x00"
